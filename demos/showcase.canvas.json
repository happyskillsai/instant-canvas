{
	"instantcanvas": 1,
	"title": "Full showcase",
	"description": "Every display block and every form component in one canvas.",
	"pages": [
		{
			"name": "Charts & data",
			"blocks": [
				{ "type": "markdown", "text": "## Display blocks\nEvery renderer: KPI deltas in all three states, multi-series **line**, grouped **bar**, **pie** and **donut**, a fully formatted **table**, and a markdown block loaded from a file (below)." },
				{ "type": "kpi", "cards": [
					{ "label": "Revenue", "value": 482000, "format": "currency", "currency": "USD", "delta": { "value": 0.18, "label": "YoY", "positiveIs": "up" } },
					{ "label": "Churn", "value": 0.031, "format": "percent", "delta": { "value": -0.06, "label": "QoQ", "positiveIs": "down" } },
					{ "label": "NPS", "value": 61, "format": "number", "delta": { "value": 0.00002, "label": "QoQ" } },
					{ "label": "Region", "value": "APAC", "format": "none" }
				]},
				{ "type": "chart", "kind": "line", "title": "Traffic vs conversions", "description": "Two series, smoothed via the raw ECharts options escape hatch",
					"data": [
						{ "week": "W1", "visits": 12400, "conversions": 810 },
						{ "week": "W2", "visits": 14100, "conversions": 940 },
						{ "week": "W3", "visits": 13100, "conversions": 1010 },
						{ "week": "W4", "visits": 16800, "conversions": 1290 },
						{ "week": "W5", "visits": 17550, "conversions": 1410 },
						{ "week": "W6", "visits": 16200, "conversions": 1495 }
					],
					"encoding": { "x": "week", "y": ["visits", "conversions"] },
					"format": { "y": "number" },
					"options": { "series": [{ "smooth": true }, { "smooth": true }] } },
				{ "type": "chart", "kind": "bar", "title": "Cost per region", "description": "Grouped bars, currency axis",
					"data": [
						{ "region": "APAC", "infra": 42000, "people": 118000 },
						{ "region": "EMEA", "infra": 38500, "people": 132000 },
						{ "region": "AMER", "infra": 61000, "people": 178000 }
					],
					"encoding": { "x": "region", "y": ["infra", "people"] },
					"format": { "y": "currency", "currency": "USD" } },
				{ "type": "chart", "kind": "pie", "title": "Traffic sources", "description": "Plain pie",
					"data": [
						{ "source": "Organic", "share": 46200 },
						{ "source": "Paid", "share": 28900 },
						{ "source": "Referral", "share": 12300 },
						{ "source": "Direct", "share": 9800 }
					],
					"encoding": { "category": "source", "value": "share" } },
				{ "type": "chart", "kind": "pie", "donut": true, "title": "Plan mix", "description": "Donut variant, percent tooltip on currency values",
					"data": [
						{ "plan": "Free", "mrr": 0 },
						{ "plan": "Pro", "mrr": 84000 },
						{ "plan": "Team", "mrr": 126000 },
						{ "plan": "Enterprise", "mrr": 272000 }
					],
					"encoding": { "category": "plan", "value": "mrr" },
					"format": { "y": "currency", "currency": "USD" } },
				{ "type": "table", "title": "Column formats: text, number, currency, percent + left align",
					"columns": [
						{ "key": "country", "label": "Country" },
						{ "key": "code", "label": "Code", "format": "text", "align": "left" },
						{ "key": "users", "label": "Users", "format": "number" },
						{ "key": "arpu", "label": "ARPU", "format": "currency", "currency": "USD" },
						{ "key": "growth", "label": "Growth", "format": "percent" }
					],
					"rows": [
						{ "country": "Australia", "code": "AU", "users": 48210, "arpu": 23.4, "growth": 0.124 },
						{ "country": "Japan", "code": "JP", "users": 91520, "arpu": 18.1, "growth": 0.078 },
						{ "country": "Germany", "code": "DE", "users": 55870, "arpu": 21.7, "growth": -0.012 }
					]},
				{ "type": "markdown", "src": "demos/showcase-notes.md" }
			]
		},
		{
			"name": "Every form component",
			"blocks": [
				{ "type": "markdown", "text": "## The complete form vocabulary\nAll **16 field types**, fieldset grids (2 and 3 columns, spans), segmented buttons, pill multi-select, and the bespoke date/datetime/select widgets." },
				{
					"type": "form",
					"title": "Component gallery",
					"description": "Writes to demos/showcase.output.json — submit or cancel freely.",
					"destination": { "kind": "json", "path": "demos/showcase.output.json", "mode": "merge" },
					"submitLabel": "Save everything",
					"fields": [
						{
							"type": "fieldset", "legend": "Text inputs", "description": "text, email, tel, url in a 2-column grid; textarea spanning both.", "columns": 2,
							"fields": [
								{ "name": "fullName", "label": "Full name (text)", "type": "text", "required": true, "placeholder": "Grace Hopper", "validation": { "minLength": 2, "maxLength": 60 } },
								{ "name": "email", "label": "Email", "type": "email", "required": true, "placeholder": "grace@navy.mil" },
								{ "name": "phone", "label": "Phone (tel)", "type": "tel", "placeholder": "+1 555 0100" },
								{ "name": "website", "label": "Website (url)", "type": "url", "placeholder": "https://grace.dev" },
								{ "name": "bio", "label": "Bio (textarea)", "type": "textarea", "span": 2, "placeholder": "A couple of sentences…", "validation": { "maxLength": 400 } }
							]
						},
						{
							"type": "fieldset", "legend": "Secrets & numbers", "description": "secret with eye reveal; number, range and readonly in a 3-column grid.", "columns": 3,
							"fields": [
								{ "name": "apiToken", "label": "API token (secret)", "type": "secret", "required": true, "span": 3, "help": "Masked, eye-revealable, redacted from every agent output.", "validation": { "minLength": 6 } },
								{ "name": "seats", "label": "Seats (number)", "type": "number", "default": 5, "validation": { "min": 1, "max": 500, "step": 1 } },
								{ "name": "quality", "label": "Quality (range)", "type": "range", "validation": { "min": 0, "max": 100, "step": 5 }, "default": 65 },
								{ "name": "plan", "label": "Plan (readonly)", "type": "readonly", "default": "team-annual" }
							]
						},
						{
							"type": "fieldset", "legend": "Dates & choices", "columns": 2,
							"fields": [
								{ "name": "startDate", "label": "Start date (date)", "type": "date", "required": true, "help": "Bespoke calendar — click month/year to jump." },
								{ "name": "kickoff", "label": "Kickoff (datetime)", "type": "datetime", "help": "Calendar + time section + Done." },
								{ "name": "region", "label": "Region (select)", "type": "select", "required": true, "options": [
									{ "label": "Asia-Pacific", "value": "apac" },
									{ "label": "Europe, Middle East & Africa", "value": "emea" },
									{ "label": "Americas", "value": "amer" }
								] },
								{ "name": "tier", "label": "Support tier (radio)", "type": "radio", "options": ["Basic", "Priority", "Dedicated"], "default": "Priority" }
							]
						},
						{
							"type": "fieldset", "legend": "Variants & toggles",
							"fields": [
								{ "name": "environment", "label": "Environment (select, ui buttons)", "type": "select", "ui": "buttons", "options": ["development", "staging", "production"], "default": "staging" },
								{ "name": "integrations", "label": "Integrations (checkboxGroup, ui pills)", "type": "checkboxGroup", "ui": "pills", "required": true, "default": ["github"], "options": [
									{ "label": "GitHub", "value": "github" },
									{ "label": "Slack", "value": "slack" },
									{ "label": "Linear", "value": "linear" },
									{ "label": "Datadog", "value": "datadog" },
									{ "label": "PagerDuty", "value": "pagerduty" },
									{ "label": "Stripe", "value": "stripe" }
								] },
								{ "name": "alerts", "label": "Alert channels (checkboxGroup, classic)", "type": "checkboxGroup", "options": ["Email", "SMS", "Push"], "default": ["Email"] },
								{ "name": "terms", "label": "I accept the terms (checkbox)", "type": "checkbox", "required": true }
							]
						},
						{ "name": "source", "type": "hidden", "default": "showcase-demo" }
					]
				}
			]
		}
	]
}
