{
	"instantcanvas": 1,
	"createdWith": "0.2.1",
	"title": "Form kitchen sink",
	"description": "Every field type, plus fieldset grids, segmented buttons and pill multi-select.",
	"blocks": [
		{
			"type": "markdown",
			"text": "## All 16 field types + layout\nA **conference registration** that uses every component: grouped fieldsets with 2-column grids, the bespoke select and date/datetime pickers, segmented buttons (`\"ui\": \"buttons\"`), pill multi-select (`\"ui\": \"pills\"`), custom radios, checkboxes and slider."
		},
		{
			"type": "form",
			"title": "Conference registration",
			"description": "Nothing serious — submit or cancel freely, it writes to demos/kitchen-sink.output.json.",
			"destination": { "kind": "json", "path": "demos/kitchen-sink.output.json", "mode": "merge" },
			"submitLabel": "Register",
			"cancelLabel": "Never mind",
			"fields": [
				{
					"type": "fieldset",
					"legend": "Identity",
					"columns": 2,
					"fields": [
						{ "name": "fullName", "label": "Full name", "type": "text", "required": true, "placeholder": "Ada Lovelace", "span": 2, "validation": { "minLength": 2, "maxLength": 60 } },
						{ "name": "email", "label": "Email address", "type": "email", "required": true, "placeholder": "ada@example.com" },
						{ "name": "phone", "label": "Phone", "type": "tel", "placeholder": "+61 400 000 000" },
						{ "name": "website", "label": "Website", "type": "url", "placeholder": "https://ada.dev" },
						{ "name": "dateOfBirth", "label": "Date of birth", "type": "date", "required": true },
						{ "name": "streetAddress", "label": "Street address", "type": "textarea", "span": 2, "placeholder": "42 Analytical Engine Way\nSydney NSW 2000", "validation": { "maxLength": 300 } }
					]
				},
				{
					"type": "fieldset",
					"legend": "Event",
					"description": "Bespoke select, datetime picker with time, and steppers.",
					"columns": 2,
					"fields": [
						{ "name": "ticketType", "label": "Ticket type", "type": "select", "required": true, "options": [
							{ "label": "Community — free", "value": "community" },
							{ "label": "Standard — $299", "value": "standard" },
							{ "label": "Enterprise — $999", "value": "enterprise" }
						] },
						{ "name": "arrival", "label": "Arrival (date & time)", "type": "datetime", "help": "Same calendar, plus a time section and Done." },
						{ "name": "attendees", "label": "Number of attendees", "type": "number", "required": true, "default": 1, "validation": { "min": 1, "max": 20, "step": 1 } },
						{ "name": "spiceLevel", "label": "Dinner spice level", "type": "range", "validation": { "min": 0, "max": 10, "step": 1 }, "default": 4 }
					]
				},
				{
					"type": "fieldset",
					"legend": "Preferences",
					"fields": [
						{ "name": "tshirtSize", "label": "T-shirt size", "type": "radio", "ui": "buttons", "options": ["S", "M", "L", "XL"], "default": "M", "help": "Segmented buttons — ui \"buttons\" on a radio field." },
						{ "name": "workshops", "label": "Workshops", "type": "checkboxGroup", "ui": "pills", "required": true, "options": [
							{ "label": "Agent security 101", "value": "security" },
							{ "label": "Canvas-driven UIs", "value": "canvas" },
							{ "label": "Zero-dependency Node", "value": "node" },
							{ "label": "ECharts deep dive", "value": "echarts" },
							{ "label": "Prompt engineering", "value": "prompts" }
						], "default": ["canvas"], "help": "Pill multi-select — ui \"pills\" on a checkboxGroup. Type to filter, click to add, ✕ to remove." },
						{ "name": "dietary", "label": "Dietary requirements", "type": "checkboxGroup", "options": ["Vegetarian", "Vegan", "Gluten-free", "Halal"], "help": "Classic checkboxes — now bespoke." },
						{ "name": "billing", "label": "Billing", "type": "radio", "options": [
							{ "label": "Personal card", "value": "personal" },
							{ "label": "Company invoice", "value": "invoice" }
						], "default": "personal", "help": "Classic radios — now bespoke." }
					]
				},
				{ "name": "accessCode", "label": "Access code", "type": "secret", "required": true, "help": "Masked, eye-revealable, never returned to the agent.", "validation": { "minLength": 6 } },
				{ "name": "newsletter", "label": "Subscribe to the newsletter", "type": "checkbox", "default": "true" },
				{ "name": "referredBy", "label": "Referred by", "type": "readonly", "default": "instant-canvas demo" },
				{ "name": "campaignId", "type": "hidden", "default": "ks-2026-07" }
			]
		}
	]
}
