{
  "instantcanvas": 1,
  "createdWith": "0.3.1",
  "title": "Project Setup — Atlas Demo",
  "description": "Kitchen-sink form: all 16 field types across three fieldsets, writing to example/.env.demo (never the chat).",
  "blocks": [
    {
      "type": "markdown",
      "text": "# Configure the Atlas demo\n\nEverything you type here is written to `example/.env.demo` on disk. **Secret values never reach the agent or the chat** — it only learns the field names."
    },
    {
      "type": "form",
      "destination": {
        "kind": "env",
        "path": "example/.env.demo",
        "mode": "merge"
      },
      "submitLabel": "Save configuration",
      "fields": [
        {
          "type": "fieldset",
          "legend": "Project",
          "description": "Where and how the demo runs.",
          "columns": 2,
          "fields": [
            {
              "name": "PROJECT_NAME",
              "label": "Project name",
              "type": "text",
              "required": true,
              "placeholder": "atlas-demo",
              "validation": {
                "minLength": 3,
                "maxLength": 40
              }
            },
            {
              "name": "ENVIRONMENT",
              "label": "Environment",
              "type": "select",
              "options": [
                "development",
                "staging",
                "production"
              ],
              "default": "staging",
              "ui": "buttons"
            },
            {
              "name": "REGION",
              "label": "Region",
              "type": "select",
              "options": [
                "us-east-1",
                "eu-west-1",
                "ap-southeast-2"
              ],
              "default": "ap-southeast-2"
            },
            {
              "name": "TEAM_EMAIL",
              "label": "Team email",
              "type": "email",
              "required": true,
              "placeholder": "team@example.com"
            },
            {
              "name": "PROJECT_URL",
              "label": "Project URL",
              "type": "url",
              "placeholder": "https://atlas.example.com",
              "validation": {
                "protocols": [
                  "https"
                ]
              },
              "help": "https only."
            },
            {
              "name": "ONCALL_PHONE",
              "label": "On-call phone",
              "type": "tel",
              "placeholder": "+61 400 000 000"
            }
          ]
        },
        {
          "type": "fieldset",
          "legend": "Credentials",
          "description": "Stored on disk, redacted everywhere else.",
          "columns": 1,
          "fields": [
            {
              "name": "OPENAI_API_KEY",
              "label": "OpenAI API key",
              "type": "secret",
              "required": true,
              "placeholder": "sk-…"
            },
            {
              "name": "DATABASE_URL",
              "label": "Database URL",
              "type": "secret",
              "placeholder": "postgres://…"
            },
            {
              "name": "WEBHOOK_SIGNING_SECRET",
              "label": "Webhook signing secret",
              "type": "secret",
              "validation": {
                "minLength": 16
              },
              "help": "At least 16 characters."
            }
          ]
        },
        {
          "type": "fieldset",
          "legend": "Tuning & rollout",
          "columns": 3,
          "fields": [
            {
              "name": "MAX_TOKENS",
              "label": "Max tokens",
              "type": "number",
              "default": 4096,
              "validation": {
                "min": 256,
                "max": 128000,
                "step": 256
              }
            },
            {
              "name": "TEMPERATURE",
              "label": "Temperature",
              "type": "range",
              "default": 0.7,
              "validation": {
                "min": 0,
                "max": 2,
                "step": 0.1
              }
            },
            {
              "name": "LOG_LEVEL",
              "label": "Log level",
              "type": "radio",
              "options": [
                "debug",
                "info",
                "warn",
                "error"
              ],
              "default": "info",
              "ui": "buttons"
            },
            {
              "name": "LAUNCH_DATE",
              "label": "Launch date",
              "type": "date",
              "default": "2026-08-03"
            },
            {
              "name": "MAINTENANCE_START",
              "label": "Maintenance window",
              "type": "datetime"
            },
            {
              "name": "ENABLE_TELEMETRY",
              "label": "Enable anonymous telemetry",
              "type": "checkbox",
              "default": false
            },
            {
              "name": "FEATURE_FLAGS",
              "label": "Feature flags",
              "type": "checkboxGroup",
              "options": [
                "analytics",
                "billing",
                "sso",
                "audit_log",
                "webhooks",
                "exports"
              ],
              "ui": "pills",
              "span": 2
            },
            {
              "name": "ROLLOUT_NOTES",
              "label": "Rollout notes",
              "type": "textarea",
              "placeholder": "Anything the on-call should know…",
              "span": 3
            },
            {
              "name": "CLIENT_ID",
              "label": "Client id",
              "type": "hidden",
              "default": "atlas-demo-001"
            },
            {
              "name": "SDK_VERSION",
              "label": "SDK version",
              "type": "readonly",
              "default": "3.2.1"
            }
          ]
        }
      ]
    }
  ]
}
