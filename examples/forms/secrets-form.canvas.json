{
  "instantcanvas": 1,
  "createdWith": "0.20.0",
  "title": "Environment secrets",
  "description": "Collect API keys and secrets into a .env file. Secret values reach the browser and disk only — the agent receives field names and { \"redacted\": true }, never the values.",
  "blocks": [
    {
      "type": "form",
      "title": "Set up environment variables",
      "description": "These are written (merged) into examples/forms/.env. Existing keys are preserved.",
      "destination": { "kind": "env", "path": "examples/forms/.env", "mode": "merge" },
      "submitLabel": "Save secrets",
      "fields": [
        {
          "type": "fieldset",
          "legend": "Database & API",
          "columns": 1,
          "fields": [
            { "name": "DATABASE_URL", "label": "Database URL", "type": "url", "required": true, "placeholder": "postgres://localhost:5432/bikeshare", "validation": { "protocols": ["postgres", "postgresql"] } },
            { "name": "API_BASE_URL", "label": "API base URL", "type": "url", "validation": { "protocols": ["https"] } }
          ]
        },
        {
          "type": "fieldset",
          "legend": "Secrets",
          "columns": 1,
          "fields": [
            { "name": "OPENAI_API_KEY", "label": "OpenAI API key", "type": "secret", "required": true, "validation": { "minLength": 20 }, "help": "sk-… — masked with a reveal toggle." },
            { "name": "JWT_SECRET", "label": "JWT signing secret", "type": "secret", "validation": { "minLength": 16 } }
          ]
        },
        {
          "type": "fieldset",
          "legend": "Runtime",
          "columns": 2,
          "fields": [
            { "name": "LOG_LEVEL", "label": "Log level", "type": "select", "options": ["debug", "info", "warn", "error"], "default": "info", "ui": "buttons" },
            { "name": "NODE_ENV", "label": "Node env", "type": "select", "options": ["development", "production"], "default": "development" }
          ]
        }
      ]
    }
  ]
}
