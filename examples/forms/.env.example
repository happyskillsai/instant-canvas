# Development secrets template — copy to `.env`, then edit it live in the browser:
#   npx -y @happyskillsai/instant-canvas open examples/forms/.env
# `open` on any .env / .env.* file synthesises a masked edit form; the values
# reach the browser and disk only — never the agent's chat.
DATABASE_URL=postgres://localhost:5432/bikeshare
API_BASE_URL=https://api.example.com
OPENAI_API_KEY=sk-REPLACE_ME
JWT_SECRET=change-me-in-development
LOG_LEVEL=debug
